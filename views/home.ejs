<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>Home Page</title>
</head>
<body>
  <%- include('./partials/nav') %>

  <div class="container mt-3">
    <div class="row">

      <% blogs.forEach((blog) => { %>

        <div class="col-md-4 mb-3">
          <div class="card h-100">

      <img
  src="/blog/image/<%= blog._id %>"
  class="card-img-top"
  style="
    height:250px;
    object-fit:contain;
    background:#f8f9fa;
  "
  alt="<%= blog.title %>"
>
            <div class="card-body">
              <h5 class="card-title">
                <%= blog.title %>
              </h5>

              <a href="/blog/<%= blog._id%>" class="btn btn-primary">
                View
              </a>
            </div>

          </div>
        </div>

      <% }) %>

    </div>
  </div>

  <%- include('./partials/scripts') %>
</body>
</html>