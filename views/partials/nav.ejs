<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="/">Blogify</a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left Side -->
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link active" href="/">Home</a>
        </li>

        <% if (locals.user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/blog/add-new">
              Add Blog
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/user/profile">
              My Profile
            </a>
          </li>
        <% } %>
      </ul>

      <!-- Right Side -->
      <ul class="navbar-nav ms-auto">

        <% if (locals.user) { %>

          <li class="nav-item dropdown">

            <a
              class="nav-link dropdown-toggle d-flex align-items-center gap-2"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
            >
              <img
                src="<%= locals.user.profileImageURL %>"
                width="35"
                height="35"
                class="rounded-circle"
                style="object-fit: cover;"
              >

              <span><%= locals.user.fullName %></span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end">

              <li>
                <a class="dropdown-item" href="/user/profile">
                  👤 Profile
                </a>
              </li>

              <li>
                <a class="dropdown-item" href="/user/my-blogs">
                  📝 My Blogs
                </a>
              </li>

              <li><hr class="dropdown-divider"></li>

              <li>
                <a class="dropdown-item text-danger" href="/user/logout">
                  🚪 Logout
                </a>
              </li>

            </ul>

          </li>

        <% } else { %>

          <li class="nav-item">
            <a class="nav-link" href="/user/signin">
              Sign In
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/user/signup">
              Create Account
            </a>
          </li>

        <% } %>

      </ul>

    </div>
  </div>
</nav>

<% if (locals.error) { %>
  <div class="container mt-4">
    <div class="alert alert-danger">
      <%= locals.error %>
    </div>
  </div>
<% } %>