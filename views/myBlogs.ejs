<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>My Blogs</title>
</head>
<body>

<%- include('./partials/nav') %>

<div class="container mt-4">
  <h1>My Blogs</h1>

  <% if (blogs.length === 0) { %>
    <p>You haven't written any blogs yet.</p>
  <% } %>

  <div class="row">

    <% blogs.forEach(blog => { %>

      <div class="col-md-4 mb-3">
        <div class="card">

          <img
            src="<%= blog.coverImageURL %>"
            class="card-img-top"
          >

          <div class="card-body">
            <h5><%= blog.title %></h5>

            <a
              href="/blog/<%= blog._id %>"
              class="btn btn-primary"
            >
              View
            </a>
          </div>

        </div>
      </div>

    <% }) %>

  </div>
</div>

<%- include('./partials/scripts') %>

</body>
</html>