<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title><%= blog.title %></title>
</head>
<body>

  <%- include('./partials/nav') %>

  <!-- Blog Content -->
  <div class="container mt-5" style="max-width: 900px;">

    <!-- Title -->
    <h1 class="text-center mb-4 fw-bold">
      <%= blog.title %>
    </h1>

    <!-- Cover Image -->
    <img
      src="/blog/image/<%= blog._id %>"
      class="img-fluid rounded shadow-sm w-100"
      style="max-height: 60vh; object-fit: cover;"
      alt="<%= blog.title %>"
    />

    <!-- Author Section -->
    <div class="d-flex align-items-center gap-3 mt-4 mb-4">

      <% if (blog.createdBy) { %>

        <img
          src="<%= blog.createdBy.profileImageURL %>"
          width="60"
          height="60"
          class="rounded-circle border"
          style="object-fit: cover;"
        />

        <div>
          <h6 class="mb-0">
            <%= blog.createdBy.fullName %>
          </h6>

          <small class="text-muted">
            Author
          </small>
        </div>

      <% } else { %>

        <img
          src="/images/default.png"
          width="60"
          height="60"
          class="rounded-circle border"
          style="object-fit: cover;"
        />

        <div>
          <h6 class="mb-0">
            Unknown Author
          </h6>
        </div>

      <% } %>

    </div>

    <!-- Blog Body -->
    <div
      class="p-3 bg-light rounded shadow-sm"
      style="
        line-height: 1.9;
        font-size: 1.1rem;
        text-align: justify;
        white-space: pre-wrap;
      "
    >
      <%= blog.body %>
    </div>

    <!-- Comments Section -->
    <div class="mt-5">

      <h3 class="mb-4">
        Comments (<%= comments.length %>)
      </h3>

      <!-- Add Comment Form -->
      <% if (locals.user) { %>

        <form method="POST" action="/blog/comment/<%= blog._id %>">

          <div class="mb-3">

            <textarea
              class="form-control"
              name="content"
              rows="3"
              placeholder="Write your comment..."
              required
            ></textarea>

          </div>

          <button
            class="btn btn-primary"
            type="submit"
          >
            Add Comment
          </button>

        </form>

      <% } %>

      <!-- Comments List -->
      <div class="mt-4">

        <% comments.forEach(comment => { %>

          <div class="card mb-3 shadow-sm">

            <div class="card-body">

              <div class="d-flex align-items-center gap-3 mb-3">

                <% if (comment.createdBy) { %>

                  <img
                    src="<%= comment.createdBy.profileImageURL %>"
                    width="50"
                    height="50"
                    class="rounded-circle border"
                    style="object-fit: cover;"
                  />

                  <div>
                    <h6 class="mb-0">
                      <%= comment.createdBy.fullName %>
                    </h6>
                  </div>

                <% } else { %>

                  <img
                    src="/images/default.png"
                    width="50"
                    height="50"
                    class="rounded-circle border"
                    style="object-fit: cover;"
                  />

                  <div>
                    <h6 class="mb-0">
                      Unknown User
                    </h6>
                  </div>

                <% } %>

              </div>

              <p
                class="mb-0"
                style="
                  white-space: pre-wrap;
                  line-height: 1.7;
                "
              >
                <%= comment.content %>
              </p>

            </div>

          </div>

        <% }) %>

      </div>

    </div>

  </div>

  <%- include('./partials/scripts') %>

</body>
</html>