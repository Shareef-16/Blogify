<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>Blog</title>
</head>
<body>
  <%- include('./partials/nav') %>

  <div class="container mt-4">
    <h1><%= blog.title %></h1>
    <img src="<%= blog.coverImageURL %>" width="700px" />
    <p class="mt-3"><%= blog.body %></p>
  </div>

  <div class="container mt-4">
    <% if (blog.createdBy) { %>
      <img src="<%= blog.createdBy.profileImageURL %>" width="100px" />
      <p><%= blog.createdBy.fullName %></p>
    <% } else { %>
      <img src="/images/default.png" width="100px" />
      <p>Unknown Author</p>
    <% } %>
  </div>

  <div class="container mt-3">
    <h1>Comments (<%= comments.length %>)</h1>

    <% if (locals.user) { %>
      <form method="POST" action="/blog/comment/<%= blog._id %>">
        <div class="mb-3">
          <input
            type="text"
            class="form-control"
            name="content"
            placeholder="Enter Your Comment"
          />
          <button class="btn btn-sm btn-primary" type="submit">
            Add
          </button>
        </div>
      </form>
    <% } %>

    <div class="mt-3">
      <% comments.forEach(comment => { %>
        <div class="mb-3 border p-3 rounded">

          <% if (comment.createdBy) { %>
            <img src="<%= comment.createdBy.profileImageURL %>" width="50px" />
            <p><%= comment.createdBy.fullName %></p>
          <% } else { %>
            <img src="/images/default.png" width="50px" />
            <p>Unknown User</p>
          <% } %>

          <pre><%= comment.content %></pre>

        </div>
      <% }) %>
    </div>
  </div>

  <%- include('./partials/scripts') %>
</body>
</html>